# ─────────────────────────────────────────────────────────────────────────────
#  Secrets file — DO NOT COMMIT TO GIT
# ─────────────────────────────────────────────────────────────────────────────
# This file is gitignored. Keep a backup outside the repo.
# Copy secrets.nix.example and fill in your real values.
# ─────────────────────────────────────────────────────────────────────────────
{
  # ── Git identity ────────────────────────────────
  git = {
    name = "Leonardo Nava (L3oNav)";
    email = "l3onav@outlook.com";
    signingkey = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIBwRbVMLmqtlo7TYoOaPWegtlYdlizxBGC+wX9DDWHPq";
  };

  # ── Obsidian MCP Bearer Token ───────────────────
  # Rotate this token immediately if the repo has ever been pushed to a public remote.
  obsidian-bearer-token = "YOUR_OBSIDIAN_BEARER_TOKEN";

  # ── Sistema 3 Capas — Secrets ───────────────────
  #
  # NOTA: Estos secrets se almacenan como archivos en el sistema,
  # no directamente en este archivo Nix. Este archivo es solo
  # referencia para que recuerdes qué secrets necesitas configurar.
  #
  # ── Capa 1: OpenClaw ────────────────────────────
  # Almacena estos valores como archivos:
  #
  #   sudo mkdir -p /var/lib/openclaw
  #
  #   # API Key del proveedor de modelos (OpenRouter, Anthropic, etc.)
  #   echo "sk-or-v1-TU_KEY" | sudo tee /var/lib/openclaw/model-api-key
  #   sudo chmod 600 /var/lib/openclaw/model-api-key
  #   sudo chown openclaw:openclaw /var/lib/openclaw/model-api-key
  #
  #   # (Opcional) Telegram Bot Token
  #   echo "123456:ABC-DEF..." | sudo tee /var/lib/openclaw/telegram-token
  #   sudo chmod 600 /var/lib/openclaw/telegram-token
  #   sudo chown openclaw:openclaw /var/lib/openclaw/telegram-token
  #
  #   # (Opcional) Discord Bot Token
  #   echo "TU_DISCORD_TOKEN" | sudo tee /var/lib/openclaw/discord-token
  #   sudo chmod 600 /var/lib/openclaw/discord-token
  #   sudo chown openclaw:openclaw /var/lib/openclaw/discord-token
  #
  #   # Auth token del gateway (auto-generado en primer arranque)
  #   # Obtener con: sudo cat /var/lib/openclaw/auth-token
  #
  # ── Capa 2: Hermes ──────────────────────────────
  # Ya configurado: /var/lib/hermes/env
  # Contiene: OPENROUTER_API_KEY=sk-or-v1-TU_KEY
  #
  # ── Capa 3: OpenCode ────────────────────────────
  # Configura en tu shell (~/.zshrc o variables de entorno):
  #   export OPENROUTER_API_KEY="sk-or-v1-TU_KEY"
  # O en ~/.config/opencode/config.json
}
