# ──────────────────────────────────────────────────
#  Secrets template — copy to secrets.nix and fill in
# ──────────────────────────────────────────────────
# cp secrets.nix.example secrets.nix
# Then edit secrets.nix with your real values.
# secrets.nix is gitignored.
# ──────────────────────────────────────────────────
{
  # ── Git identity ────────────────────────────────
  git = {
    name = "Your Name";
    email = "your-email@example.com";
    signingkey = "ssh-ed25519 AAAA...";
  };

  # ── Obsidian MCP Bearer Token ───────────────────
  obsidian-bearer-token = "your-token-here";
}
